<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #2F3136;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.ChatController">
    <children>
        <HBox prefHeight="700.0" prefWidth="1000.0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <VBox minWidth="240.0" prefWidth="240.0"
                  style="-fx-background-color: #2F3136;">

                <children>
                    <HBox alignment="CENTER_LEFT" prefHeight="48.0" prefWidth="240.0"
                          style="-fx-border-color: #202225; -fx-border-width: 0 0 1 0;">
                        <padding><Insets left="15.0" right="8.0"/></padding>
                        <children>
                            <Label fx:id="currentChannelLabel"
                                   style="-fx-text-fill: white;"
                                   text="Чаты" HBox.hgrow="ALWAYS">
                                <font><Font name="System Bold" size="14.0"/></font>
                            </Label>
                            <Button onAction="#handleCreateChat"
                                    text="+"
                                    style="-fx-background-color: #5865F2; -fx-text-fill: white; -fx-background-radius: 50; -fx-min-width: 28; -fx-min-height: 28; -fx-max-width: 28; -fx-max-height: 28; -fx-cursor: hand;">
                                <font><Font name="System Bold" size="16.0"/></font>
                            </Button>
                        </children>
                    </HBox>

                    <ListView fx:id="chatsList"
                              VBox.vgrow="ALWAYS"
                              style="-fx-background-color: #2F3136; -fx-background: #2F3136; -fx-control-inner-background: #2F3136; -fx-border-color: transparent;"/>
                </children>
            </VBox>

            <VBox style="-fx-background-color: #36393F;"
                  HBox.hgrow="ALWAYS">

                <children>

                    <ListView fx:id="messagesList"
                              VBox.vgrow="ALWAYS"
                              style="-fx-background-color: #36393F; -fx-background: #36393F; -fx-control-inner-background: #36393F; -fx-border-color: transparent;"/>

                    <HBox alignment="CENTER"
                          minHeight="80.0"
                          prefHeight="80.0"
                          spacing="15.0">

                        <padding>
                            <Insets left="20.0" right="20.0"/>
                        </padding>

                        <children>
                            <TextField fx:id="messageInput"
                                       prefHeight="44.0"
                                       promptText="Написать сообщение..."
                                       style="-fx-background-color: #40444B; -fx-text-fill: white; -fx-prompt-text-fill: #72767D; -fx-background-radius: 8;"
                                       HBox.hgrow="ALWAYS"/>

                            <Button mnemonicParsing="false"
                                    onAction="#handleSendMessage"
                                    prefHeight="44.0"
                                    prefWidth="100.0"
                                    text="ОТПРАВИТЬ"
                                    style="-fx-background-color: #5865F2; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;">

                                <font>
                                    <Font name="System Bold" size="12.0"/>
                                </font>
                            </Button>
                        </children>
                    </HBox>

                </children>
            </VBox>

        </HBox>
    </children>
</AnchorPane>
