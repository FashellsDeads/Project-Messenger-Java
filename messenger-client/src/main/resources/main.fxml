<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #2F3136;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.ChatController">
    <children>
        <HBox prefHeight="700.0" prefWidth="1000.0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <!-- Панель каналов (теперь левая самая) -->
            <VBox minWidth="240.0" prefWidth="240.0"
                  style="-fx-background-color: #2F3136;">

                <children>
                    <Label fx:id="currentChannelLabel"
                           prefHeight="48.0" prefWidth="240.0"
                           style="-fx-border-color: #202225; -fx-border-width: 0 0 1 0; -fx-text-fill: white;"
                           text="Каналы">

                        <padding>
                            <Insets left="15.0"/>
                        </padding>

                        <font>
                            <Font name="System Bold" size="14.0"/>
                        </font>
                    </Label>

                    <ListView fx:id="channelsList"
                              VBox.vgrow="ALWAYS"
                              style="-fx-background-color: transparent;"/>
                </children>
            </VBox>

            <!-- ЧАТ -->
            <VBox style="-fx-background-color: #36393F;"
                  HBox.hgrow="ALWAYS">

                <children>

                    <ListView fx:id="messagesList"
                              VBox.vgrow="ALWAYS"
                              style="-fx-background-color: transparent;"/>

                    <HBox alignment="CENTER"
                          minHeight="80.0"
                          prefHeight="80.0"
                          spacing="15.0">

                        <padding>
                            <Insets left="20.0" right="20.0"/>
                        </padding>

                        <children>
                            <TextField fx:id="messageInput"
                                       prefHeight="44.0"
                                       promptText="Написать сообщение..."
                                       style="-fx-background-color: #40444B; -fx-text-fill: white; -fx-background-radius: 8;"
                                       HBox.hgrow="ALWAYS"/>

                            <Button mnemonicParsing="false"
                                    onAction="#handleSendMessage"
                                    prefHeight="44.0"
                                    prefWidth="100.0"
                                    text="ОТПРАВИТЬ"
                                    style="-fx-background-color: #5865F2; -fx-text-fill: white; -fx-background-radius: 8;">

                                <font>
                                    <Font name="System Bold" size="12.0"/>
                                </font>
                            </Button>
                        </children>
                    </HBox>

                </children>
            </VBox>

        </HBox>
    </children>
</AnchorPane>