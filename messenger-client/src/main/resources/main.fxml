<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #36393f;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.ChatController">
   <children>
      <HBox prefHeight="700.0" prefWidth="1000.0">
         <children>
            <VBox prefHeight="700.0" prefWidth="118.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleAddServer" prefHeight="25.0" prefWidth="120.0" text="Button" />
                  <ListView fx:id="serverList" prefHeight="680.0" prefWidth="118.0" />
               </children>
            </VBox>
            <VBox prefHeight="700.0" prefWidth="178.0">
               <children>
                  <Label fx:id="currentServerLabel" prefHeight="27.0" prefWidth="178.0" text="Label" />
                  <ListView fx:id="channelsList" prefHeight="679.0" prefWidth="178.0" />
               </children>
            </VBox>
            <VBox prefHeight="700.0" prefWidth="684.0">
               <children>
                  <ListView fx:id="messagesList" prefHeight="651.0" prefWidth="684.0" />
                  <HBox prefHeight="79.0" prefWidth="684.0">
                     <children>
                        <TextField fx:id="messageInput" prefHeight="64.0" prefWidth="593.0" />
                         <Button mnemonicParsing="false" onAction="#handleSendMessage" prefHeight="65.0" prefWidth="106.0" text="Отправить" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>

</AnchorPane>
