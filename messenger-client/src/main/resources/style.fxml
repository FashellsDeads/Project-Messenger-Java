<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #2F3136;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.MainController">
   <children>
      <!-- Центральная карточка -->
      <VBox alignment="CENTER" layoutX="340.0" layoutY="130.0" prefWidth="320.0" spacing="20.0" style="-fx-background-color: #36393F; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 10, 0, 0, 4);">
         <children>
            <VBox alignment="CENTER" spacing="8.0">
               <children>
                  <Label text="Добро пожаловать!" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <Label text="Мы так рады видеть вас снова!" textFill="#B9BBBE">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
               </children>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </VBox>

            <VBox spacing="15.0">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="ЛОГИН" textFill="#B9BBBE">
                           <font>
                              <Font name="System Bold" size="11.0" />
                           </font>
                        </Label>
                        <TextField fx:id="loginField" prefHeight="40.0" style="-fx-background-color: #202225; -fx-text-fill: white; -fx-background-radius: 3;" />
                     </children>
                  </VBox>

                  <VBox spacing="5.0">
                     <children>
                        <Label fx:id="emailLabel" text="ЭЛЕКТРОННАЯ ПОЧТА" textFill="#B9BBBE">
                           <font>
                              <Font name="System Bold" size="11.0" />
                           </font>
                        </Label>
                        <TextField fx:id="emailField" prefHeight="40.0" style="-fx-background-color: #202225; -fx-text-fill: white; -fx-background-radius: 3;" />
                     </children>
                  </VBox>

                  <VBox spacing="5.0">
                     <children>
                        <Label text="ПАРОЛЬ" textFill="#B9BBBE">
                           <font>
                              <Font name="System Bold" size="11.0" />
                           </font>
                        </Label>
                        <PasswordField fx:id="passwordField" prefHeight="40.0" style="-fx-background-color: #202225; -fx-text-fill: white; -fx-background-radius: 3;" />
                     </children>
                  </VBox>
               </children>
            </VBox>

            <Button fx:id="mainActionBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleMainAction" prefHeight="44.0" style="-fx-background-color: #5865F2; -fx-text-fill: white; -fx-background-radius: 3; -fx-cursor: hand;" text="Войти">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Button>

            <Button fx:id="switchModeBtn" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#toggleMode" style="-fx-background-color: transparent; -fx-text-fill: #00AFF4; -fx-cursor: hand; -fx-padding: 0;" text="Нужен аккаунт? Зарегистрироваться" underline="false">
               <font>
                  <Font size="13.0" />
               </font>
            </Button>
         </children>
         <padding>
            <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
         </padding>
      </VBox>

      <Label fx:id="statusLabel" alignment="CENTER" layoutY="620.0" prefWidth="1000.0" textFill="#ED4245" AnchorPane.bottomAnchor="40.0">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>
   </children>
</AnchorPane>