<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #36393f;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.MainController">
   <children>
      <Label fx:id="statusLabel" alignment="CENTER" layoutX="-11.0" layoutY="616.0" nodeOrientation="LEFT_TO_RIGHT" prefHeight="70.0" prefWidth="1000.0" text="" textAlignment="CENTER">
         <font>
            <Font name="Comic Sans MS" size="18.0" />
         </font>
      </Label>
      <Button fx:id="mainActionBtn" layoutX="401.0" layoutY="161.0" mnemonicParsing="false" onAction="#handleMainAction" prefHeight="30.0" prefWidth="201.0" text="Войти" />
      <Button fx:id="switchModeBtn" layoutX="401.0" layoutY="201.0" mnemonicParsing="false" onAction="#toggleMode" prefHeight="30.0" prefWidth="201.0" text="Нет аккаунта? Регистрация" />
      <VBox layoutX="356.0" layoutY="14.0" prefHeight="147.0" prefWidth="327.0" spacing="20.0">
         <children>
            <TextField fx:id="loginField" prefHeight="26.0" prefWidth="268.0" />
            <TextField fx:id="emailField" prefHeight="26.0" prefWidth="268.0" />
            <PasswordField fx:id="passwordField" prefHeight="26.0" prefWidth="268.0" />
         </children>
      </VBox>
   </children>
</AnchorPane>
